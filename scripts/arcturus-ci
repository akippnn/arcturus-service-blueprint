#!/usr/bin/env bash
set -euo pipefail

revision="${1:-${GITHUB_SHA:-${CI_COMMIT_SHA:-}}}"
[[ "$revision" =~ ^[0-9a-f]{40}$ ]] || {
  echo "Arcturus CI requires the full 40-character commit SHA." >&2
  exit 2
}
for variable in REGISTRY_TOKEN ARCTURUS_DEPLOY_TOKEN; do
  [[ -n "${!variable:-}" ]] || { echo "Required CI secret $variable is missing." >&2; exit 2; }
done
registry_user="${REGISTRY_USER:-${GITHUB_ACTOR:-${GITEA_ACTOR:-}}}"
[[ -n "$registry_user" ]] || {
  echo "Registry username is missing; set REGISTRY_USER or use a runner that exports GITHUB_ACTOR/GITEA_ACTOR." >&2
  exit 2
}
command -v buildah >/dev/null 2>&1 || {
  echo "Buildah is required; application language toolchains are not required on the runner." >&2
  exit 2
}
command -v python3 >/dev/null 2>&1 || {
  echo "Python 3 is required to enforce the pre-push image-size policy." >&2
  exit 2
}
max_image_size_bytes="${ARCTURUS_MAX_IMAGE_SIZE_BYTES:-805306368}"
[[ "$max_image_size_bytes" =~ ^[1-9][0-9]*$ ]] || {
  echo "ARCTURUS_MAX_IMAGE_SIZE_BYTES must be a positive integer." >&2
  exit 2
}

run_id="${GITHUB_RUN_ID:-${CI_RUN_NUMBER:-$$}}-${GITHUB_RUN_ATTEMPT:-1}"
work_rel=".arcturus/build/$run_id"
work="$PWD/$work_rel"
graph="$work/storage"
runroot="$work/runroot"
authfile="$work/auth.json"
token_file="$work_rel/deploy.token"
plan="$work/build-plan.tsv"
mkdir -p "$graph" "$runroot"
chmod 0700 "$work"
umask 077
printf '%s\n' "$ARCTURUS_DEPLOY_TOKEN" >"$token_file"
unset ARCTURUS_DEPLOY_TOKEN
export ARCTURUS_TOKEN_FILE="$token_file"
export REGISTRY_AUTH_FILE="$authfile"
export ARCTURUS_BUILDAH_ROOT="$graph"
export ARCTURUS_BUILDAH_RUNROOT="$runroot"
cleanup() {
  buildah --root "$graph" --runroot "$runroot" rm --all >/dev/null 2>&1 || true
  buildah unshare rm -rf "$work" >/dev/null 2>&1 || rm -rf "$work" || true
}
trap cleanup EXIT INT TERM

image_size_bytes() {
  local image="$1"
  buildah --root "$graph" --runroot "$runroot" images --json "$image" |
    python3 -c '
import json
import sys
rows = json.load(sys.stdin)
if len(rows) != 1:
    raise SystemExit(f"expected one local image for {sys.argv[1]}, found {len(rows)}")
row = rows[0]
size = row.get("size", row.get("Size"))
if not isinstance(size, int) or size < 0:
    raise SystemExit(f"local image size is unavailable for {sys.argv[1]}")
print(size)
' "$image"
}

enforce_remote_image_policy() {
  local image="$1"
  local size_bytes="$2"
  python3 - "$image" "$size_bytes" "$token_file" <<'PY'
import json
import os
import sys
import urllib.error
import urllib.request

image, size_raw, token_path = sys.argv[1:]
with open(".arcturus/project.json", encoding="utf-8") as handle:
    project = json.load(handle)
service = project["service"]
api_url = os.environ.get("ARCTURUS_API_URL") or project["ci"]["apiUrl"]
payload = json.dumps(
    {"service": service, "image": image, "size_bytes": int(size_raw)},
    separators=(",", ":"),
).encode()
with open(token_path, encoding="utf-8") as handle:
    token = handle.read().strip()
request = urllib.request.Request(
    api_url.rstrip("/") + "/v1/image-policy",
    data=payload,
    method="POST",
    headers={
        "Authorization": "Bearer " + token,
        "Content-Type": "application/json",
    },
)
try:
    with urllib.request.urlopen(request, timeout=20) as response:
        body = response.read().decode("utf-8", "replace")
        if response.status != 200:
            raise SystemExit(f"Arcturus image policy returned HTTP {response.status}: {body}")
except urllib.error.HTTPError as exc:
    body = exc.read().decode("utf-8", "replace")
    if exc.code == 404:
        print(
            "Arcturus host does not yet advertise image-size-policy; "
            "the local pre-push limit remains enforced.",
            file=sys.stderr,
        )
        raise SystemExit(0)
    print(f"Arcturus image policy rejected the release (HTTP {exc.code}): {body}", file=sys.stderr)
    raise SystemExit(3 if exc.code == 413 else 2)
except urllib.error.URLError as exc:
    print(f"Arcturus image policy could not be reached: {exc}", file=sys.stderr)
    raise SystemExit(2)
PY
}

printf '%s' "$REGISTRY_TOKEN" | buildah --root "$graph" --runroot "$runroot" \
  login --authfile "$authfile" --username "$registry_user" --password-stdin \
  "${ARCTURUS_REGISTRY_HOST:?ARCTURUS_REGISTRY_HOST is required}"
unset REGISTRY_TOKEN
./scripts/arcturus-tool project preflight .arcturus/project.json --token-file "$token_file"
./scripts/arcturus-tool project validate .arcturus/project.json
export ARCTURUS_PROJECT_VALIDATED=1
./scripts/arcturus-guard
./scripts/arcturus-tool project plan .arcturus/project.json --format tsv >"$plan"

digest_args=()
while IFS=$'\t' read -r name repository context containerfile validations release_target components; do
  [[ -n "$name" && -n "$repository" && -n "$components" ]] || {
    echo "Invalid build plan row for '$name'." >&2
    exit 2
  }
  if [[ "$validations" != "-" ]]; then
    IFS=',' read -r -a targets <<<"$validations"
    for target in "${targets[@]}"; do
      buildah --root "$graph" --runroot "$runroot" bud --authfile "$authfile" \
        --file "$containerfile" --target "$target" \
        --tag "$repository:validation-$revision-$target" "$context"
    done
  fi
  target_args=()
  [[ "$release_target" == "-" ]] || target_args=(--target "$release_target")
  image="$repository:$revision"
  buildah --root "$graph" --runroot "$runroot" bud --authfile "$authfile" \
    --file "$containerfile" "${target_args[@]}" --tag "$image" "$context"
  size_bytes="$(image_size_bytes "$image")"
  printf 'Built %s: %s bytes; local pre-push limit: %s bytes\n' \
    "$image" "$size_bytes" "$max_image_size_bytes"
  if (( size_bytes > max_image_size_bytes )); then
    echo "Refusing to upload oversized image $image ($size_bytes bytes > $max_image_size_bytes bytes)." >&2
    exit 3
  fi
  enforce_remote_image_policy "$image" "$size_bytes"
  digest_file="$work_rel/$name.digest"
  buildah --root "$graph" --runroot "$runroot" push --authfile "$authfile" \
    --digestfile "$digest_file" "$image" "docker://$image"
  digest_args+=(--digest "$name=$digest_file")
done <"$plan"

./scripts/arcturus-tool project render .arcturus/project.json --revision "$revision" \
  "${digest_args[@]}" --output release.json --request-output deployment-request.json
./scripts/arcturus-tool project deploy .arcturus/project.json --request deployment-request.json \
  --token-file "$token_file"
./scripts/arcturus-tool project verify .arcturus/project.json --release release.json \
  --token-file "$token_file"
if [[ "${2:-}" == "--acceptance" ]]; then
  ./scripts/arcturus-acceptance
fi

{
  "apiVersion": "arcturus.u128.org/project/v1",
  "service": "stellar-like",
  "manifest": "arcturus.release.json",
  "ci": {
    "provider": "gitea",
    "apiUrl": "http://192.0.2.10:9090",
    "storage": "isolated",
    "deployTokenSecret": "ARCTURUS_DEPLOY_TOKEN",
    "testIntent": {"mode": "container-target"}
  },
  "registry": {
    "host": "registry.example.org",
    "userSecret": "REGISTRY_USER",
    "tokenSecret": "REGISTRY_TOKEN"
  },
  "builds": {
    "api": {
      "repository": "registry.example.org/example/stellar-like-api",
      "context": ".",
      "containerfile": "services/api/Containerfile",
      "validationTargets": ["test"],
      "releaseTarget": "runtime",
      "components": ["api"]
    },
    "web": {
      "repository": "registry.example.org/example/stellar-like-web",
      "context": ".",
      "containerfile": "web/Containerfile",
      "validationTargets": ["builder"],
      "releaseTarget": "runtime",
      "components": ["web", "db-init"]
    }
  },
  "fixedComponents": ["postgres", "redis"],
  "verification": {
    "publicUrl": "https://stellar-like.example.org",
    "publicMode": "cloudflare-challenge",
    "requireRouting": true
  }
}

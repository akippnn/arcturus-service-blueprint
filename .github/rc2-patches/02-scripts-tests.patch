diff --git a/scripts/arcturus-lifecycle b/scripts/arcturus-lifecycle
index e1ffc3d..60be8d8 100755
--- a/scripts/arcturus-lifecycle
+++ b/scripts/arcturus-lifecycle
@@ -23,10 +23,20 @@ cleanup() {
   rm -rf "$work"
 }

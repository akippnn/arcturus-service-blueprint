# Non-secret example. Run scripts/arcturus-setup to configure a real project.
ARCTURUS_SERVICE=my-app
ARCTURUS_COMPONENT=app
ARCTURUS_SERVICE_TYPE=web
ARCTURUS_IMAGE_REPOSITORY=registry.example.org/team/my-app
ARCTURUS_CONTAINERFILE=Containerfile
ARCTURUS_VALIDATION_TARGETS=test
ARCTURUS_RELEASE_TARGET=runtime
ARCTURUS_EXPOSURE=public
ARCTURUS_PORT=8080
ARCTURUS_DOMAIN=app.example.org
ARCTURUS_TLS_MODE=portal
ARCTURUS_HEALTH_KIND=systemd
ARCTURUS_HEALTH_PATH=/health
ARCTURUS_PUBLIC_VERIFICATION=http-success
ARCTURUS_RESTART=always
ARCTURUS_NETWORK=internal_routing
ARCTURUS_DEPLOY_URL=http://127.0.0.1:9090
ARCTURUS_CI=gitea
ARCTURUS_TEST_COMMAND=./scripts/ci-test.sh
ARCTURUS_BUNDLE=

    "adoption": {
        "automaticFrom": "0.99.0-rc.1 project-aware generation",
        "legacyProjects": "one-time explicit bootstrap required"
    },
    "manifestApis": [
        "arcturus.u128.org/v1",
        "arcturus.u128.org/v2"
    ],
    "manifestV1Mode": "v2-backed-routing-mirror",
    "ciProviders": [
        "gitea",
        "github",
        "generic",
        "none"
    ],
    "registryModes": [
        "external",
        "owned"
    ],
    "optionalFeatures": [
        "oci-upload-grants",
        "artifact-verification-and-receipts",
        "receipt-enforced-owned-registry"
    ]
}

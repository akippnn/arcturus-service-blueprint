{
    "schemaVersion": 1,
    "product": "arcturus-service-blueprint",
    "blueprintVersion": "1.0.0-rc.2",
    "projectApi": "arcturus.u128.org/project/v1",
    "minimumArcturusVersion": "1.0.0-rc.2",
    "requiredFeatures": [
        "authenticated-preflight",
        "legacy-compose-handoff",
        "manifest-v1-safe-routing-mirror",
